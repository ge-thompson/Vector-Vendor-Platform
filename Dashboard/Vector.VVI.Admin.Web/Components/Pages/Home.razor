@page "/"

<PageTitle>VVI Admin — Live Ops</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true"><h1 style="all:unset">Live Ops</h1></MudText>
<MudText Typo="Typo.body1" Class="mb-4">
    Baseline scaffold is running. Live Ops stat tiles, the rolling transaction feed,
    and the mini charts land in the next batch.
</MudText>

<MudGrid>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.overline">Dispatches Today</MudText>
            <MudText Typo="Typo.h4">—</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.overline">Success Rate (1h)</MudText>
            <MudText Typo="Typo.h4">—</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.overline">Active Vendors</MudText>
            <MudText Typo="Typo.h4">—</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.overline">Active Customers</MudText>
            <MudText Typo="Typo.h4">—</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>
