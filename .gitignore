# ─────────────────────────────────────────────────────────────────
# Vector Vendor Integration — .gitignore
# Keep source; exclude build artifacts, IDE state, and binary tools.
# ─────────────────────────────────────────────────────────────────

# Build outputs (regenerated by every build)
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
*.dll
*.exe
*.pdb
*.cache

# NuGet (restored by `nuget restore` / `dotnet restore`)
packages/
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/

# Visual Studio IDE state (machine-specific)
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.vcxproj.user

# Rider / VS for Mac
.idea/
*.userprefs

# Other VCS metadata (don't include SVN's bookkeeping in our git repo)
.svn/
._.svn

# OS junk
[Dd]esktop.ini
Thumbs.db
.DS_Store
ehthumbs.db
*.swp
*.swo

# MCP tooling (personal-machine binary distribution; not part of project)
MCP_LocaldbFK/

# Backups / archives (we have the unpacked source already)
FourKitesIntegration.zip
*.zip

# Database files (we have scripts in _deliverables/07_SQL_Schema/)
*.mdf
*.ldf

# Test result outputs
TestResults/
[Tt]est[Rr]esult*/

# JetBrains / ReSharper
_ReSharper.*/
*.[Rr]e[Ss]harper

# Coverage / profiling
*.coverage
*.coveragexml
*.pftrace

# Logs
*.log

# Secrets — OTR API Web.config contains DB credentials and SMTP password.
# The version-controlled reference is Web.config.template; real Web.config is
# environment-specific and stays local.
_OTR_API/Web.config
