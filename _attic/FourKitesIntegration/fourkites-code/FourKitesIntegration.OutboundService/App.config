<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8.1" />
  </startup>
  <appSettings>
    <!-- HTTP listen address for internal callers (Vector FBS).
         For production, restrict to localhost or VNet-only addresses; never expose publicly. -->
    <add key="InternalListenUrl" value="http://localhost:8080/" />

    <!-- Pre-shared key Vector FBS must send in the X-Internal-Auth header.
         Generate a random 256-bit value and store in your credential vault — this is here as a placeholder. -->
    <add key="InternalAuthToken" value="CHANGE_ME_TO_RANDOM_VALUE" />

    <!-- FourKites environment selector and credentials.
         For production, load ApiKey from a credential vault at startup, NOT from this file. -->
    <add key="FourKites.Environment" value="Staging" />
    <add key="FourKites.BaseHost" value="api-staging.fourkites.com" />
    <add key="FourKites.ApiKey" value="REPLACE_FROM_VAULT" />
    <add key="FourKites.MaxRetryAttempts" value="3" />

    <!-- SQL Server connection string for transaction logging. -->
    <add key="ConnectionString" value="Server=YOUR_SQL_SERVER;Database=VectorFBS;Integrated Security=SSPI;TrustServerCertificate=true" />
  </appSettings>
</configuration>
