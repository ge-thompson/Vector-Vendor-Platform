<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <configSections>
    <section name="vendorAdapters"
             type="Vendor.Common.Configuration.VendorAdaptersSection, Vendor.Common" />
  </configSections>

  <appSettings>
    <!-- Connection string for the dispatcher's audit + profile reads. -->
    <add key="VendorDispatch.AuditConnectionString"
         value="Server=(localdb)\mssqllocaldb;Database=VendorAPI_FK;Integrated Security=True;TrustServerCertificate=True" />

    <!-- Sync dispatch in tests so we can assert state immediately after Dispatch returns. -->
    <add key="VendorDispatch.FireAndForget" value="false" />
    <add key="VendorDispatch.Enabled" value="true" />
  </appSettings>

  <!--
    Test adapter is in the test assembly itself; reflection finds it via
    assembly name "Vendor.Common.Dispatch.Smoke".
  -->
  <vendorAdapters>
    <adapters>
      <add vendorName="FourKites"
           adapterType="Vendor.Common.Dispatch.Smoke.TestFourKitesAdapter, Vendor.Common.Dispatch.Smoke" />
    </adapters>
  </vendorAdapters>

</configuration>
