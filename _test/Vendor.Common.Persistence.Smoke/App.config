<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <!--
      DEV-ONLY connection string. Points at LocalDB.
      Production code will use VendorDispatch.AuditConnectionString from Web.config
      on the OTR API / VB.NET app side; this is purely for the persistence smoke test.
    -->
    <add key="VendorAPI_FK.ConnectionString"
         value="Server=(localdb)\mssqllocaldb;Database=VendorAPI_FK;Integrated Security=True;TrustServerCertificate=True" />
  </appSettings>
</configuration>
