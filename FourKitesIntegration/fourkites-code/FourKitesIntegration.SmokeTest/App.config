<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8.1" />
  </startup>
  <appSettings>
    <add key="FourKites.BaseHost" value="api-staging.fourkites.com" />
    <add key="FourKites.ApiKey" value="REPLACE_WITH_YOUR_STAGING_KEY" />

    <!-- Smoke test settings — change these to match a real test load you've registered. -->
    <add key="SmokeTest.BillToCode" value="TEST_SHIPPER" />
    <add key="SmokeTest.Carrier" value="ABCD" />
    <add key="SmokeTest.LoadNumberPrefix" value="SMOKE" />
  </appSettings>
</configuration>
