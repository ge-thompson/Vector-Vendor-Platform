<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8.1" />
  </startup>
  <appSettings>
    <!-- Public-facing listen URL. In production, this should be the URL FourKites POSTs to.
         Use https:// in production behind a reverse proxy or with a real cert bound via netsh http add sslcert. -->
    <add key="PublicListenUrl" value="http://+:8081/" />

    <!-- Webhook auth. FourKites supports Basic, API Key header, or OAuth2 per the canonical API Reference.
         (The Knowledge Base lists more options including Bearer Token, Session-Based Bearer, and Nonce-Based,
         but those need CSM confirmation before relying on them.)
         Pick ONE and set it here. The receiver enforces this. -->
    <add key="WebhookAuthMode" value="ApiKey" />  <!-- "Basic" | "ApiKey" | "None" -->
    <add key="WebhookAuthHeader" value="X-FourKites-Token" />
    <add key="WebhookAuthValue" value="CHANGE_ME_TO_RANDOM_VALUE" />

    <!-- For Basic auth mode: -->
    <add key="WebhookBasicUser" value="fourkites" />
    <add key="WebhookBasicPassword" value="CHANGE_ME" />

    <!-- SQL Server connection string for InboundCallbacks logging. -->
    <add key="ConnectionString" value="Server=YOUR_SQL_SERVER;Database=VectorFBS;Integrated Security=SSPI;TrustServerCertificate=true" />

    <!-- Dedup window: how long to retain dedupe hashes (hours). 48h covers all FourKites retry windows. -->
    <add key="DedupWindowHours" value="48" />

    <!-- Background webhook correlator settings.
         The correlator runs inside this same service and scans FourKitesInboundCallbacks for
         unprocessed rows, matching them against FourKitesOutboundTransactions.
         Set PollIntervalSeconds higher (e.g. 60) for low-volume shops, lower (5) for high volume. -->
    <add key="WebhookCorrelator.PollIntervalSeconds" value="10" />
    <add key="WebhookCorrelator.BatchSize" value="100" />
  </appSettings>
</configuration>
